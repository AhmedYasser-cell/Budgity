<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="700.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="src.setFinancialGoalController">
  <children>
    <AnchorPane maxHeight="-1.0" maxWidth="-1.0" prefHeight="-1.0" prefWidth="-1.0" VBox.vgrow="ALWAYS">
      <children>
            <VBox layoutX="20.0" layoutY="20.0" prefWidth="660.0" spacing="20.0">
               <children>
                  <VBox spacing="10.0" styleClass="card">
                     <children>
                        <Label styleClass="header-label" text="Set Financial Goal" />
                        <HBox spacing="15.0">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Goal Name" />
                                    <TextField fx:id="goalNameField" prefWidth="120.0" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Target Amount" />
                                    <TextField fx:id="targetAmountField" prefWidth="100.0" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Current Amount" />
                                    <TextField fx:id="currentAmountField" prefWidth="100.0" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Monthly Income" />
                                    <TextField fx:id="monthlyIncomeField" prefWidth="100.0" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Target Date" />
                                    <DatePicker fx:id="targetDatePicker" prefWidth="130.0" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Button fx:id="addGoalButton" mnemonicParsing="false" onAction="#handleAddGoal" text="Add Goal" />
                              <Button fx:id="editGoalButton" mnemonicParsing="false" onAction="#handleEditGoal" text="Edit Goal" />
                              <Button fx:id="deleteGoalButton" mnemonicParsing="false" onAction="#handleDeleteGoal" text="Delete" />
                              <HBox HBox.hgrow="ALWAYS" />
                              <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" text="Back" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <TableView fx:id="goalsTable" prefHeight="238.0" prefWidth="660.0">
                    <columns>
                      <TableColumn fx:id="goalNameColumn" prefWidth="150.0" text="Goal Name" />
                      <TableColumn fx:id="targetColumn" prefWidth="120.0" text="Target" />
                        <TableColumn fx:id="currentColumn" prefWidth="130.0" text="Current Balance" />
                        <TableColumn fx:id="incomeColumn" prefWidth="120.0" text="Income" />
                        <TableColumn fx:id="progressColumn" prefWidth="100.0" text="Progress" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
      </children>
    </AnchorPane>
  </children>
</VBox>
